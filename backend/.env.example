# Database
DATABASE_URL="postgresql://rewards:rewards@localhost:5432/driversbonus?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_64"
JWT_REFRESH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_64"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption (for PII fields)
ENCRYPTION_KEY="CHANGE_ME_32_byte_hex_key"

# Server
PORT=3000
NODE_ENV="development"
ALLOWED_ORIGINS="http://localhost:3001,chrome-extension://YOUR_EXTENSION_ID"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Gift Card Provider (placeholder)
GIFT_CARD_API_URL="https://api.giftcardprovider.example.com"
GIFT_CARD_API_KEY="CHANGE_ME"

# Logging
LOG_LEVEL="info"
